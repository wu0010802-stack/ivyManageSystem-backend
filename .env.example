# 環境識別 (development | production)
ENV=development

# 資料庫連線字串（正式環境必須設定）
DATABASE_URL=postgresql://localhost:5432/ivymanagement

# JWT 密鑰（正式環境必須設定，建議 32+ 字元隨機字串）
# JWT_SECRET_KEY=your-production-secret-key-here

# CORS 允許來源（逗號分隔，開發環境預設 localhost:5173）
# CORS_ORIGINS=http://localhost:5173,https://my-app.example.com
